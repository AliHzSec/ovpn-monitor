# Server
ADDR=0.0.0.0:80

# Admin credentials
ADMIN_USER=admin
ADMIN_PASS=changeme

# OpenVPN
OPENVPN_STATUS_LOG=/var/log/openvpn/status.log
OPENVPN_CERT_DIR=/etc/openvpn/certs
OPENVPN_IPP_FILE=/etc/openvpn/server/ipp.txt
OPENVPN_CLIENT_SUBNET=172.16.22.0/24

# Database
DB_PATH=./db.sqlite

# Session
SESSION_TTL=24h

# Templates
TEMPLATES_DIR=./templates